<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="Kursinis" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.kursinis.entities.User</class>
        <class>com.example.kursinis.entities.Restaurant</class>
        <class>com.example.kursinis.entities.MenuItem</class>
        <class>com.example.kursinis.entities.Order</class>
        <class>com.example.kursinis.entities.OrderItem</class>
        <class>com.example.kursinis.entities.Review</class>
        <class>com.example.kursinis.entities.Client</class>
        <class>com.example.kursinis.entities.Owner</class>
        <class>com.example.kursinis.entities.Driver</class>
        <class>com.example.kursinis.entities.Admin</class>
        <class>com.example.kursinis.entities.Message</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:file:../data/kursinisDB;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.use_sql_comments" value="true"/>
        </properties>
    </persistence-unit>
</persistence>